---
# Example secrets file for Ansible configuration
# Copy to secrets.yml and customize for your environment
# Then encrypt with: ansible-vault encrypt secrets.yml

# ============================================================================
# LDAP Configuration
# ============================================================================

# LDAP server URIs (space-separated)
ldap_uri: "ldaps://ldap1.example.com/ ldaps://ldap2.example.com/"

# LDAP base DN
ldap_base: "dc=example,dc=com"

# SASL mechanism (GSSAPI, PLAIN, etc.)
ldap_sasl_mech: "GSSAPI"

# SASL canonicalization (on/off)
ldap_sasl_nocanon: "on"

# TLS certificate verification (demand, allow, try, never)
ldap_tls_reqcert: "demand"

# LDAP host for SSH host key lookups
ldap_host: "ldap://ldap.example.com"

# Kerberos realm
kerberos_realm: "EXAMPLE.COM"

# ============================================================================
# Dist-git Bastion Configuration
# ============================================================================

# Bastion host for dist-git access (hostname for distgit-bastion alias)
distgit_bastion_host: "bastion-iad2.example.com"

# ============================================================================
# COPR Repositories
# ============================================================================

# List of COPR repositories to enable
# Format: "host/owner/project" or "owner/project" (defaults to copr.fedorainfracloud.org)
# Common internal COPR repositories:
# copr_repositories:
#  - "owner/project"  # Example public COPR repo
#  - "copr.example.com/owner/project"  # Example custom COPR instance
#  - "copr.devel.some-host.com/@ousera/repo-a"
#  - "copr.devel.some-host.com/userb/repo-b"


# To disable COPR repositories, set to empty list:
copr_repositories: []

# ============================================================================
# RCM Tools Repository
# ============================================================================

# RCM Tools repository base URL
#  requires VPN connection for corporate
rcm_tools_baseurl: "https://your-mirror.example.com/rcmtools/$releasever/$basearch/"

# RCM Tools GPG key (Red Hat internal GPG key)
# Replace with GPG key if using custom repository
rcm_tools_gpg_key: |
  -----BEGIN PGP PUBLIC KEY BLOCK-----
  Version: GnuPG v2.0.22 (GNU/Linux)
   add-key
  -----END PGP PUBLIC KEY BLOCK-----

# To use a custom GPG key, replace the entire block above with your key

# ============================================================================
# CA Certificates
# ============================================================================

# List of CA certificate files to install
ca_certificates:
  2022-IT-Root-CA.pem: |
    -----BEGIN CERTIFICATE-----
    add cert
    -----END CERTIFICATE-----

  2015-IT-Root-CA.pem: |
    -----BEGIN CERTIFICATE-----
    add cert
    -----END CERTIFICATE-----


# To disable certificate installation:
# ca_certificates: []
